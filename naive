#!/usr/bin/env bash
# naive — CLI-панель для naiveproxy (Caddy + forwardproxy@naive).
# Точка входа. После установки склеивается с lib/*.sh в один файл.
#
# Использование:
#   naive                 — главное меню
#   naive install         — первичная установка (TLS, юзер, маскарад)
#   naive uninstall       — удаление
#   naive users ...       — подкоманды users (add/delete/list/...)
#   naive traffic ...     — vnstat обёртка
#   naive tls ...         — состояние/renew сертификата
#   naive masquerade ...  — смена маскарада
#   naive restart|reload  — управление сервисом
#   naive info            — сводка + список юзеров
#   naive upgrade ...     — self | caddy
#   naive log ...         — access | service
#   naive version         — версия

set -euo pipefail

# lib/ подгружаются ниже (при склейке install.sh добавляет их в этот файл).
# В режиме разработки — source'им их напрямую, если запущены из git tree.
# Auto-discovery: подхватываем любые lib/*.sh, не хардкодим список.
# common.sh и config.sh source'ятся ПЕРВЫМИ явно — от них зависят все остальные
# (NAIVE_* пути, логгер, prompt), и glob-порядок не гарантирован.
if [[ -d "${BASH_SOURCE[0]%/*}/lib" ]]; then
  _naive_lib_dir="${BASH_SOURCE[0]%/*}/lib"
  # shellcheck source=lib/common.sh
  source "$_naive_lib_dir/common.sh"
  # shellcheck source=lib/config.sh
  source "$_naive_lib_dir/config.sh"
  for f in "$_naive_lib_dir/"*.sh; do
    [[ -f "$f" ]] || continue
    case "$(basename "$f")" in
      common.sh|config.sh) ;;  # уже загружены
      *) source "$f" ;;
    esac
  done
  unset _naive_lib_dir
fi

# Заглушки — перекрываются реальными из lib/*.sh при их наличии.
# Один паттерн: declare -F guard + сообщение "не реализовано".
_naive_stub() { log_warn "naive: '$1' not implemented (missing lib module?)"; }
_naive_stub_q() { return 0; }   # тихий stub (для функций-хелперов, не критичных для UX)

if ! declare -F caddy_reload_safe >/dev/null; then caddy_reload_safe() { _naive_stub_q; }; fi
if ! declare -F _sub_show_creds     >/dev/null; then _sub_show_creds()     { _naive_stub "subscription/creds"; }; fi
if ! declare -F _sub_show_uri       >/dev/null; then _sub_show_uri()       { _naive_stub "subscription/uri"; }; fi
if ! declare -F _sub_show_qr        >/dev/null; then _sub_show_qr()        { _naive_stub "subscription/qr"; }; fi
if ! declare -F _sub_show_loginpass >/dev/null; then _sub_show_loginpass() { _naive_stub "subscription/loginpass"; }; fi
if ! declare -F _sub_show_json_all  >/dev/null; then _sub_show_json_all()  { _naive_stub "subscription/json"; }; fi
if ! declare -F _sub_show_b64       >/dev/null; then _sub_show_b64()       { _naive_stub "subscription/b64"; }; fi
if ! declare -F tls_issue           >/dev/null; then tls_issue()           { _naive_stub "tls_issue"; }; fi
if ! declare -F cmd_uninstall       >/dev/null; then cmd_uninstall()       { _naive_stub "uninstall"; }; fi
if ! declare -F cmd_restart         >/dev/null; then cmd_restart()         { _naive_stub "restart"; }; fi
if ! declare -F cmd_reload          >/dev/null; then cmd_reload()          { _naive_stub "reload"; }; fi
if ! declare -F cmd_log             >/dev/null; then cmd_log()             { _naive_stub "log"; }; fi

# Эти функции переопределяются только если соответствующий модуль не source'нут.
# (lib/users.sh определяет users_menu, lib/install.sh — lib_install_main и т.д.)
if ! declare -F submenu_users    >/dev/null; then submenu_users()    { _naive_stub "users menu"; }; fi
if ! declare -F submenu_traffic  >/dev/null; then submenu_traffic()  { _naive_stub "traffic menu"; }; fi
if ! declare -F submenu_tls      >/dev/null; then submenu_tls()      { _naive_stub "tls menu"; }; fi
if ! declare -F submenu_masquerade >/dev/null; then submenu_masquerade() { _naive_stub "masquerade menu"; }; fi
if ! declare -F info_summary     >/dev/null; then info_summary()     { _naive_stub "info_summary"; }; fi
if ! declare -F dispatch_upgrade >/dev/null; then dispatch_upgrade() { _naive_stub "upgrade"; }; fi

# Установка и версия — простые команды, не подменяются модулями.
cmd_install() { lib_install_main; }
cmd_info()    { info_summary; }
cmd_version() { printf "%s v%s\n" "$NAIVE_TITLE" "$NAIVE_VERSION"; }
usage() {
  cat <<EOF
Usage: naive [command]

Commands:
  (none)        interactive main menu
  install       first-time setup (TLS, user, masquerade, caddy)
  uninstall     remove everything installed by naive-panel
  users         manage users submenu
  traffic       vnstat traffic submenu
  tls           certificate status / renew
  masquerade    change masquerade site
  restart       systemctl restart naive-caddy
  reload        caddy reload (zero-downtime)
  log           tail access log / service log
  info          show summary + users
  upgrade       upgrade self | caddy
  version       print version
EOF
}

# --- главное меню ---
main_menu() {
  while :; do
    banner "$(status_summary)"
    cat <<EOF
  1. Users
  2. Masquerade site
  3. TLS / certificates
  4. Traffic statistics
  5. Restart Caddy
  6. Reload Caddy
  7. View access log
  8. View Caddy service log
  9. Show connection details
 10. Update Caddy (rebuild via xcaddy)
 11. Update panel
 12. Uninstall
  0. Exit
EOF
    printf -- "-------------------------------------------------------------\n"
    prompt_choice 12 || { printf "Bye.\n"; exit 0; }
    case "$CHOICE" in
      1)  submenu_users ;;
      2)  submenu_masquerade ;;
      3)  submenu_tls ;;
      4)  submenu_traffic ;;
      5)  cmd_restart ;;
      6)  cmd_reload ;;
      7)  cmd_log access ;;
      8)  cmd_log service ;;
      9)  cmd_info ;;
      10) cmd_upgrade caddy ;;
      11) cmd_upgrade self ;;
      12) cmd_uninstall ;;
      0)  printf "Bye.\n"; exit 0 ;;
    esac
  done
}

# --- диспетчер ---
case "${1:-menu}" in
  menu)         main_menu ;;
  install)      cmd_install ;;
  uninstall)    cmd_uninstall ;;
  users)        shift; submenu_users "$@" ;;
  traffic)      shift; submenu_traffic "$@" ;;
  tls)          shift; submenu_tls "$@" ;;
  masquerade)   shift; submenu_masquerade "$@" ;;
  restart)      cmd_restart ;;
  reload)       cmd_reload ;;
  log)          shift; cmd_log "$@" ;;
  info)         cmd_info ;;
  upgrade)      shift; cmd_upgrade "$@" ;;
  version)      cmd_version ;;
  -h|--help|help) usage ;;
  *) usage; exit 2 ;;
esac