#!/usr/bin/env bash
# naive — CLI-панель для naiveproxy (Caddy + forwardproxy@naive).
# Точка входа. После установки склеивается с lib/*.sh в один файл.
#
# Использование:
#   naive                 — главное меню
#   naive install         — первичная установка (TLS, юзер, маскарад)
#   naive uninstall       — удаление
#   naive users ...       — подкоманды users (add/delete/list/...)
#   naive traffic ...     — vnstat обёртка
#   naive tls ...         — состояние/renew сертификата
#   naive masquerade ...  — смена маскарада
#   naive restart|reload  — управление сервисом
#   naive info            — сводка + список юзеров
#   naive upgrade ...     — self | caddy
#   naive log ...         — access | service
#   naive version         — версия

set -euo pipefail

# lib/ подгружаются ниже (при склейке install.sh добавляет их в этот файл).
# В режиме разработки — source'им их напрямую, если запущены из git tree.
if [[ -d "${BASH_SOURCE[0]%/*}/lib" ]]; then
  # shellcheck source=lib/common.sh
  source "${BASH_SOURCE[0]%/*}/lib/common.sh"
  # shellcheck source=lib/config.sh
  source "${BASH_SOURCE[0]%/*}/lib/config.sh"
  # shellcheck source=lib/users.sh
  source "${BASH_SOURCE[0]%/*}/lib/users.sh"
fi

# --- позднее подключение модулей: каждый — no-op заглушка, если не найден ---
for mod in caddy_config caddy_admin subscription qr traffic tls masquerade bootstrap uninstall install upgrade; do
  if [[ -f "${BASH_SOURCE[0]%/*}/lib/${mod}.sh" ]]; then
    # shellcheck source=lib/caddy_admin.sh
    # shellcheck source=lib/subscription.sh
    # shellcheck source=lib/qr.sh
    # shellcheck source=lib/traffic.sh
    # shellcheck source=lib/tls.sh
    # shellcheck source=lib/masquerade.sh
    # shellcheck source=lib/bootstrap.sh
    # shellcheck source=lib/uninstall.sh
    source "${BASH_SOURCE[0]%/*}/lib/${mod}.sh"
  fi
done

# Заглушки для ещё-не-реализованных команд — перекрываются реальными lib/*.sh
# при их наличии.
if ! declare -F caddy_reload_safe >/dev/null; then caddy_reload_safe() { return 0; }; fi
if ! declare -F _sub_show_creds >/dev/null; then _sub_show_creds() { log_warn "subscription: not implemented"; }; fi
if ! declare -F _sub_show_uri >/dev/null; then _sub_show_uri() { log_warn "subscription: not implemented"; }; fi
if ! declare -F _sub_show_qr >/dev/null; then _sub_show_qr() { log_warn "subscription/qr: not implemented"; }; fi
if ! declare -F _sub_show_loginpass >/dev/null; then _sub_show_loginpass() { log_warn "subscription: not implemented"; }; fi
if ! declare -F _sub_show_json_all >/dev/null; then _sub_show_json_all() { log_warn "subscription: not implemented"; }; fi
if ! declare -F _sub_show_b64 >/dev/null; then _sub_show_b64() { log_warn "subscription: not implemented"; }; fi
if ! declare -F tls_issue >/dev/null; then tls_issue() { log_warn "tls: not implemented"; }; fi

# --- подкоманды-заглушки; реализация подключится в следующих шагах ---
todo() { log_warn "[$1] not implemented yet — see plan task #$2"; }

cmd_install()    { cmd_install_main; }
cmd_uninstall()  { todo uninstall 14; }
submenu_users()  { users_menu; }
submenu_traffic(){ traffic_menu; }
submenu_tls()    { tls_menu; }
submenu_masquerade(){ masquerade_menu; }
cmd_restart()    { todo restart 5; }
cmd_reload()     { todo reload 5; }
cmd_log()        { todo log 7; }
cmd_info()       { info_summary; }
cmd_upgrade()    { dispatch_upgrade "$@"; }
cmd_version()    { printf "%s v%s\n" "$NAIVE_TITLE" "$NAIVE_VERSION"; }
usage() {
  cat <<EOF
Usage: naive [command]

Commands:
  (none)        interactive main menu
  install       first-time setup (TLS, user, masquerade, caddy)
  uninstall     remove everything installed by naive-panel
  users         manage users submenu
  traffic       vnstat traffic submenu
  tls           certificate status / renew
  masquerade    change masquerade site
  restart       systemctl restart naive-caddy
  reload        caddy reload (zero-downtime)
  log           tail access log / service log
  info          show summary + users
  upgrade       upgrade self | caddy
  version       print version
EOF
}

# --- главное меню ---
main_menu() {
  while :; do
    banner "$(status_summary)"
    cat <<EOF
  1. Users
  2. Masquerade site
  3. TLS / certificates
  4. Traffic statistics
  5. Restart Caddy
  6. Reload Caddy
  7. View access log
  8. View Caddy service log
  9. Show connection details
 10. Update Caddy (rebuild via xcaddy)
 11. Update panel
 12. Uninstall
  0. Exit
EOF
    printf -- "-------------------------------------------------------------\n"
    prompt_choice 12 || { printf "Bye.\n"; exit 0; }
    case "$CHOICE" in
      1)  submenu_users ;;
      2)  submenu_masquerade ;;
      3)  submenu_tls ;;
      4)  submenu_traffic ;;
      5)  cmd_restart ;;
      6)  cmd_reload ;;
      7)  cmd_log access ;;
      8)  cmd_log service ;;
      9)  cmd_info ;;
      10) cmd_upgrade caddy ;;
      11) cmd_upgrade self ;;
      12) cmd_uninstall ;;
      0)  printf "Bye.\n"; exit 0 ;;
    esac
  done
}

# --- диспетчер ---
case "${1:-menu}" in
  menu)         main_menu ;;
  install)      cmd_install ;;
  uninstall)    cmd_uninstall ;;
  users)        shift; submenu_users "$@" ;;
  traffic)      shift; submenu_traffic "$@" ;;
  tls)          shift; submenu_tls "$@" ;;
  masquerade)   shift; submenu_masquerade "$@" ;;
  restart)      cmd_restart ;;
  reload)       cmd_reload ;;
  log)          shift; cmd_log "$@" ;;
  info)         cmd_info ;;
  upgrade)      shift; cmd_upgrade "$@" ;;
  version)      cmd_version ;;
  -h|--help|help) usage ;;
  *) usage; exit 2 ;;
esac